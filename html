<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#1a1a2e">
    <title>🚛 Логистическая система АПК</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg-primary: #1a1a2e;
            --bg-secondary: #16213e;
            --bg-card: #0f3460;
            --accent: #00d4ff;
            --accent-hover: #00a8cc;
            --text-primary: #e0e0e0;
            --text-secondary: #8888aa;
            --success: #6bff6b;
            --warning: #ffd93d;
            --danger: #ff6b6b;
            --spoiled: #FF5722;
            --purple: #CE93D8;
            --border: #333355;
        }

        html {
            font-size: 16px;
            -webkit-text-size-adjust: 100%;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-card) 100%);
            padding: 1rem;
            border-bottom: 2px solid var(--accent);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .header h1 {
            color: var(--accent);
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            flex: 1;
            min-width: 200px;
        }

        .header-controls {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .day-indicator {
            background: rgba(156, 39, 176, 0.15);
            border: 2px solid #9C27B0;
            border-radius: 8px;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--purple);
            font-size: 0.95rem;
            font-weight: bold;
        }

        .day-indicator .day-value {
            font-size: 1.3rem;
            color: var(--accent);
        }

        .auto-timer {
            background: rgba(0, 212, 255, 0.08);
            border: 1px dashed rgba(0, 212, 255, 0.4);
            border-radius: 6px;
            padding: 0.4rem 0.8rem;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

        .auto-timer .timer-value {
            color: var(--accent);
            font-weight: bold;
        }

        /* Navigation */
        .nav-tabs {
            display: flex;
            background-color: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
            padding: 0 0.5rem;
            gap: 0.25rem;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }

        .nav-tabs::-webkit-scrollbar {
            display: none;
        }

        .nav-tab {
            padding: 0.9rem 1.2rem;
            background: none;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            transition: all 0.3s;
            border-bottom: 3px solid transparent;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .nav-tab:hover {
            color: var(--text-primary);
            background-color: rgba(0, 212, 255, 0.1);
        }

        .nav-tab.active {
            color: var(--accent);
            border-bottom-color: var(--accent);
        }

        /* Container */
        .container {
            padding: 1rem;
            max-width: 1600px;
            margin: 0 auto;
        }

        .tab-content { display: none; }
        .tab-content.active { display: block; animation: fadeIn 0.3s; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Grids */
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        .grid-4 { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem; }

        /* Cards */
        .card {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.25rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.2);
            margin-bottom: 1.5rem;
        }

        .card h3 {
            color: var(--accent);
            margin-bottom: 1rem;
            font-size: 1rem;
            border-bottom: 1px solid var(--border);
            padding-bottom: 0.5rem;
        }

        /* Metric Cards */
        .metric-card {
            background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-secondary) 100%);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1rem;
            text-align: center;
            transition: transform 0.3s, box-shadow 0.3s;
            position: relative;
            overflow: hidden;
        }

        .metric-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: var(--accent);
            transform: scaleX(0);
            transition: transform 0.3s;
        }

        .metric-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 16px rgba(0, 212, 255, 0.2);
        }

        .metric-card:hover::before { transform: scaleX(1); }

        .metric-icon { font-size: 2rem; margin-bottom: 0.3rem; }
        .metric-value { font-size: 1.5rem; font-weight: bold; color: var(--accent); margin: 0.3rem 0; }
        .metric-label { color: var(--text-secondary); font-size: 0.8rem; }

        /* Map */
        .map-container {
            position: relative;
            border-radius: 10px;
            border: 2px solid var(--border);
            overflow: hidden;
            background: linear-gradient(180deg, #0a0f1e 0%, #141e37 50%, #1e2d4b 100%);
        }

        #custom-map {
            width: 100%;
            height: 500px;
            display: block;
        }

        /* Tables */
        .table-container {
            overflow-x: auto;
            background-color: var(--bg-secondary);
            border-radius: 10px;
            border: 1px solid var(--border);
            -webkit-overflow-scrolling: touch;
        }

        table { width: 100%; border-collapse: collapse; min-width: 600px; }
        th, td { padding: 0.6rem 0.8rem; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.85rem; }

        th {
            background-color: var(--bg-card);
            color: var(--accent);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            position: sticky;
            top: 0;
        }

        tr:hover { background-color: rgba(0, 212, 255, 0.05); }
        tr.selected { background-color: rgba(0, 212, 255, 0.15); border-left: 3px solid var(--accent); }

        /* Forms */
        .form-group { margin-bottom: 1rem; }
        label { display: block; margin-bottom: 0.4rem; color: var(--text-secondary); font-size: 0.85rem; }

        input, select {
            width: 100%;
            padding: 0.7rem;
            background-color: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 5px;
            color: var(--text-primary);
            font-size: 0.95rem;
            transition: border-color 0.3s;
        }

        input:focus, select:focus { outline: none; border-color: var(--accent); }

        /* Buttons */
        .btn {
            padding: 0.7rem 1.2rem;
            border: none;
            border-radius: 5px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            min-height: 44px;
            touch-action: manipulation;
        }

        .btn-primary { background-color: var(--accent); color: var(--bg-primary); }
        .btn-primary:hover { background-color: var(--accent-hover); transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0, 212, 255, 0.4); }
        .btn-success { background-color: var(--success); color: var(--bg-primary); }
        .btn-warning { background-color: var(--warning); color: var(--bg-primary); }
        .btn-danger { background-color: var(--danger); color: white; }

        .btn-block { width: 100%; }

        /* Badges */
        .badge { padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; display: inline-block; }
        .badge-success { background-color: rgba(107, 255, 107, 0.2); color: var(--success); border: 1px solid var(--success); }
        .badge-warning { background-color: rgba(255, 217, 61, 0.2); color: var(--warning); border: 1px solid var(--warning); }
        .badge-danger { background-color: rgba(255, 107, 107, 0.2); color: var(--danger); border: 1px solid var(--danger); }
        .badge-info { background-color: rgba(0, 212, 255, 0.2); color: var(--accent); border: 1px solid var(--accent); }
        .badge-spoiled { background-color: rgba(255, 87, 34, 0.2); color: var(--spoiled); border: 1px solid var(--spoiled); }

        /* Log Console */
        .log-console {
            background-color: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: 0.8rem;
            font-family: 'Courier New', monospace;
            font-size: 0.8rem;
            height: 250px;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

        .log-entry { margin: 0.2rem 0; padding: 0.2rem 0; word-wrap: break-word; }
        .log-time { color: var(--accent); }
        .log-success { color: var(--success); }
        .log-error { color: var(--danger); }
        .log-info { color: var(--text-secondary); }
        .log-spoiled { color: var(--spoiled); font-weight: bold; }
        .log-day { color: var(--purple); font-weight: bold; }

        /* Split View */
        .split-view { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

        /* Efficiency Summary */
        .efficiency-summary {
            background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-secondary) 100%);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 0.8rem 1rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .summary-item { display: flex; flex-direction: column; gap: 0.2rem; }
        .summary-label { font-size: 0.75rem; color: var(--text-secondary); }
        .summary-value { font-size: 1.1rem; font-weight: bold; color: var(--accent); }

        /* Recommendation Panel */
        .recommendation-panel {
            background-color: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1rem;
            margin-top: 1rem;
            max-height: 400px;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

        .recommendation-panel h4 { color: var(--accent); margin-bottom: 0.8rem; font-size: 1rem; }

        .recommendation-card {
            background: rgba(0, 212, 255, 0.05);
            border-left: 3px solid var(--accent);
            padding: 0.8rem;
            margin-bottom: 0.8rem;
            border-radius: 5px;
        }

        .recommendation-card.warehouse { background: rgba(107, 255, 107, 0.1); border-left-color: var(--success); }
        .recommendation-card.route { background: rgba(255, 217, 61, 0.1); border-left-color: var(--warning); }
        .recommendation-card.vehicle { background: rgba(0, 212, 255, 0.1); border-left-color: var(--accent); }
        .recommendation-card.savings { background: rgba(156, 39, 176, 0.15); border-left-color: #CE93D8; }
        .recommendation-card.spoiled { background: rgba(255, 87, 34, 0.15); border-left-color: var(--spoiled); }

        .recommendation-card h5 { margin-bottom: 0.4rem; font-size: 0.9rem; }
        .recommendation-card.warehouse h5 { color: var(--success); }
        .recommendation-card.route h5 { color: var(--warning); }
        .recommendation-card.vehicle h5 { color: var(--accent); }
        .recommendation-card.savings h5 { color: #CE93D8; }
        .recommendation-card.spoiled h5 { color: var(--spoiled); }

        .problem-list { list-style: none; padding: 0; margin: 0.4rem 0; }
        .problem-list li { padding: 0.2rem 0; color: var(--danger); font-size: 0.85rem; }
        .problem-list li::before { content: "⚠️ "; }

        .score-badge { display: inline-block; padding: 0.4rem 0.8rem; border-radius: 5px; font-weight: bold; font-size: 1rem; }
        .score-high { background-color: rgba(107, 255, 107, 0.2); color: var(--success); }
        .score-medium { background-color: rgba(255, 217, 61, 0.2); color: var(--warning); }
        .score-low { background-color: rgba(255, 107, 107, 0.2); color: var(--danger); }
        .score-spoiled { background-color: rgba(255, 87, 34, 0.2); color: var(--spoiled); }

        .info-box {
            color: var(--text-secondary);
            font-style: italic;
            padding: 0.8rem;
            background-color: rgba(0, 212, 255, 0.05);
            border-radius: 5px;
            border: 1px dashed rgba(0, 212, 255, 0.3);
            margin-bottom: 1rem;
            font-size: 0.85rem;
        }

        /* Warehouse Products Widget */
        .warehouse-products-header {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            margin-bottom: 0.8rem;
            flex-wrap: wrap;
        }

        .warehouse-products-header label {
            color: var(--accent);
            font-weight: bold;
            font-size: 0.9rem;
            margin: 0;
        }

        .warehouse-products-header select {
            flex: 1;
            min-width: 200px;
        }

        .warehouse-summary {
            color: var(--text-secondary);
            font-size: 0.8rem;
            margin-top: 0.5rem;
        }

        /* Mobile Optimizations */
        @media (max-width: 1024px) {
            .grid-2, .split-view { grid-template-columns: 1fr; }
            .grid-4 { grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); }
        }

        @media (max-width: 768px) {
            html { font-size: 15px; }

            .header {
                padding: 0.8rem;
                flex-direction: column;
                align-items: stretch;
            }

            .header h1 {
                font-size: 1rem;
                text-align: center;
            }

            .header-controls {
                justify-content: center;
            }

            .day-indicator, .auto-timer {
                font-size: 0.85rem;
                padding: 0.4rem 0.8rem;
            }

            .day-indicator .day-value {
                font-size: 1.1rem;
            }

            .container {
                padding: 0.8rem;
            }

            .card {
                padding: 1rem;
                margin-bottom: 1rem;
            }

            .card h3 {
                font-size: 0.95rem;
            }

            .grid-4 {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.6rem;
            }

            .metric-card {
                padding: 0.8rem;
            }

            .metric-icon {
                font-size: 1.5rem;
            }

            .metric-value {
                font-size: 1.2rem;
            }

            .metric-label {
                font-size: 0.7rem;
            }

            #custom-map {
                height: 400px;
            }

            .nav-tab {
                padding: 0.8rem 1rem;
                font-size: 0.85rem;
            }

            .btn {
                padding: 0.6rem 1rem;
                font-size: 0.85rem;
            }

            .efficiency-summary {
                gap: 1rem;
                padding: 0.6rem 0.8rem;
            }

            .summary-value {
                font-size: 1rem;
            }

            table {
                min-width: 500px;
            }

            th, td {
                padding: 0.5rem 0.6rem;
                font-size: 0.8rem;
            }
        }

        @media (max-width: 480px) {
            html { font-size: 14px; }

            .header {
                padding: 0.6rem;
            }

            .header h1 {
                font-size: 0.9rem;
            }

            .header-controls {
                flex-direction: column;
                gap: 0.5rem;
            }

            .day-indicator, .auto-timer {
                width: 100%;
                justify-content: center;
            }

            .container {
                padding: 0.6rem;
            }

            .card {
                padding: 0.8rem;
                border-radius: 8px;
            }

            .grid-4 {
                grid-template-columns: 1fr 1fr;
                gap: 0.5rem;
            }

            .metric-card {
                padding: 0.6rem;
            }

            .metric-icon {
                font-size: 1.3rem;
            }

            .metric-value {
                font-size: 1.1rem;
            }

            #custom-map {
                height: 350px;
            }

            .nav-tabs {
                padding: 0 0.3rem;
            }

            .nav-tab {
                padding: 0.7rem 0.8rem;
                font-size: 0.8rem;
            }

            .btn {
                padding: 0.5rem 0.8rem;
                font-size: 0.8rem;
                min-height: 40px;
            }

            table {
                min-width: 450px;
                font-size: 0.75rem;
            }

            th, td {
                padding: 0.4rem 0.5rem;
            }

            .warehouse-products-header {
                flex-direction: column;
                align-items: stretch;
            }

            .warehouse-products-header select {
                min-width: auto;
            }
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-primary); }
        ::-webkit-scrollbar-thumb { background: var(--bg-card); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent); }

        /* Touch improvements */
        @media (hover: none) and (pointer: coarse) {
            .btn:hover {
                transform: none;
            }

            .metric-card:hover {
                transform: none;
            }

            tr:hover {
                background-color: transparent;
            }

            tr:active {
                background-color: rgba(0, 212, 255, 0.1);
            }
        }
    </style>
</head>
<body>
    <header class="header">
        <h1>🚛 ЛОГИСТИЧЕСКАЯ СИСТЕМА АПК</h1>
        <div class="header-controls">
            <div class="day-indicator">
                <span>📅 День:</span>
                <span class="day-value" id="current-day">0</span>
            </div>
            <div class="auto-timer">
                ⏱️ Следующий день: <span class="timer-value" id="next-day-timer">90</span> сек
            </div>
        </div>
    </header>

    <nav class="nav-tabs">
        <button class="nav-tab active" onclick="switchTab('map')">📍 Карта</button>
        <button class="nav-tab" onclick="switchTab('manage')">⚙️ Управление</button>
        <button class="nav-tab" onclick="switchTab('deliveries')">📋 Доставки</button>
        <button class="nav-tab" onclick="switchTab('analytics')">📈 Аналитика</button>
    </nav>

    <div class="container">
        <!-- Map Tab -->
        <div id="map-tab" class="tab-content active">
            <div class="grid-2">
                <div>
                    <div class="map-container">
                        <canvas id="custom-map"></canvas>
                    </div>
                </div>
                <div>
                    <div class="grid-4" id="metrics-grid"></div>
                    
                    <div class="card">
                        <h3>⚡ Быстрые действия</h3>
                        <div class="info-box">
                            💡 Дни меняются автоматически каждые 1.5 минуты. Продукты портятся по истечении срока годности.
                        </div>
                        <div style="display: flex; gap: 0.8rem; flex-wrap: wrap;">
                            <button class="btn btn-success" onclick="simulateAll()">⏩ Завершить все</button>
                            <button class="btn btn-warning" onclick="refreshAll()">🔄 Обновить</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Manage Tab -->
        <div id="manage-tab" class="tab-content">
            <div class="split-view">
                <div>
                    <div class="card">
                        <h3>📦 Создать доставку</h3>
                        <form id="delivery-form" onsubmit="createDelivery(event)">
                            <div class="form-group">
                                <label>Откуда</label>
                                <select id="from-warehouse" required></select>
                            </div>
                            <div class="form-group">
                                <label>Куда</label>
                                <select id="to-warehouse" required></select>
                            </div>
                            <div class="form-group">
                                <label>Товар</label>
                                <select id="product-type" required></select>
                            </div>
                            <div class="form-group">
                                <label>Транспорт</label>
                                <select id="vehicle-type" required>
                                    <option value="TRUCK">Фура</option>
                                    <option value="GAZELLE">Газель</option>
                                    <option value="CAR">Легковой</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Количество</label>
                                <input type="number" id="quantity" min="1" max="10000" value="100" required>
                            </div>
                            <button type="submit" class="btn btn-primary btn-block">🚀 Создать доставку</button>
                        </form>
                    </div>

                    <div class="card">
                        <h3>📋 Товары на складе</h3>
                        <div class="warehouse-products-header">
                            <label>Склад:</label>
                            <select id="products-warehouse" onchange="updateProductsTable()"></select>
                        </div>
                        <div class="table-container">
                            <table id="products-table">
                                <thead>
                                    <tr>
                                        <th>Товар</th>
                                        <th>Кол-во</th>
                                        <th>Вес 1 ед.</th>
                                        <th>Общий вес</th>
                                        <th>Срок</th>
                                        <th>Осталось</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                        <div class="warehouse-summary" id="warehouse-summary"></div>
                    </div>

                    <div class="card">
                        <h3>🏭 Добавить склад</h3>
                        <form id="warehouse-form" onsubmit="addWarehouse(event)">
                            <div class="form-group">
                                <label>Название</label>
                                <input type="text" id="wh-name" required>
                            </div>
                            <div class="form-group">
                                <label>Город</label>
                                <select id="wh-city" required></select>
                            </div>
                            <div class="form-group">
                                <label>Вместимость (кг)</label>
                                <input type="number" id="wh-capacity" min="1000" max="200000" value="20000" required>
                            </div>
                            <div class="form-group">
                                <label>Мин. температура (°C)</label>
                                <input type="number" id="wh-temp-min" min="-30" max="30" value="0" required>
                            </div>
                            <div class="form-group">
                                <label>Макс. температура (°C)</label>
                                <input type="number" id="wh-temp-max" min="-10" max="50" value="25" required>
                            </div>
