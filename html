                if (data.minRemaining <= 0) {
                    remainingColor = 'var(--spoiled)';
                    remainingText = '🗑️ Испорчено';
                } else if (data.minRemaining <= 2) {
                    remainingColor = 'var(--danger)';
                } else if (data.minRemaining <= 5) {
                    remainingColor = 'var(--warning)';
                }

                return `
                    <tr>
                        <td><strong>${data.name}</strong></td>
                        <td style="text-align: center;">${data.quantity}</td>
                        <td style="text-align: center;">${data.weightPerUnit.toFixed(3)} кг</td>
                        <td style="text-align: center; font-weight: bold;">${data.totalWeight.toFixed(1)} кг</td>
                        <td style="text-align: center;">${data.shelfLife} дн.</td>
                        <td style="text-align: center; color: ${remainingColor}; font-weight: bold;">${remainingText}</td>
