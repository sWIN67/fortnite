                        quantity: 0,
                        weightPerUnit: PRODUCTS[ptype].weight,
                        totalWeight: 0,
                        shelfLife: PRODUCTS[ptype].shelfLife,
                        minRemaining: Infinity,
                        productionDay: product.productionDay
                    };
                }
                grouped[ptype].quantity += product.quantity;
                grouped[ptype].totalWeight += product.weight;
                const remaining = PRODUCTS[ptype].shelfLife - (currentDay - product.productionDay);
                if (remaining < grouped[ptype].minRemaining) {
                    grouped[ptype].minRemaining = remaining;
                }
            });

