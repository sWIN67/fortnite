        // Analytics
        function analyzeWarehouses() {
            const tbody = document.querySelector('#analysis-table tbody');
            tbody.innerHTML = '';
            
            Object.keys(CITIES).forEach(city => {
                const hasWarehouse = Object.values(warehouses).some(w => w.city === city);
                
                let minDist = Infinity;
                let nearestWh = '';
                
                Object.values(warehouses).forEach(wh => {
                    const from = CITIES[city];
                    const to = CITIES[wh.city];
                    if (from && to) {
                        const dist = calculateDistance(from, to);
                        if (dist < minDist) {
                            minDist = dist;
                            nearestWh = wh.name;
                        }
                    }
                });
                
                let recommendation, recClass;
                if (hasWarehouse) {
                    recommendation = '✅ Есть склад';
                    recClass = 'badge-success';
                } else if (minDist < 500) {
                    recommendation = `⚠️ Ближайший в ${minDist.toFixed(0)} км`;
                    recClass = 'badge-warning';
                } else {
                    recommendation = `❌ Рекомендуется склад`;
                    recClass = 'badge-danger';
                }
                
                tbody.innerHTML += `
                    <tr>
                        <td>${city}</td>
                        <td>${hasWarehouse ? '✅ Да' : '❌ Нет'}</td>
                        <td>${nearestWh}</td>
                        <td>${minDist === Infinity ? 0 : minDist.toFixed(0)}</td>
                        <td><span class="badge ${recClass}">${recommendation}</span></td>
                    </tr>
                `;
            });
            
            log('📊 Анализ выполнен', "success");
        }

        function analyzeRouteEfficiency() {
            if (deliveryHistory.length === 0) {
                alert('Сначала выполните доставку');
                return;
            }

            const recentDeliveries = deliveryHistory.slice(-20);
            efficiencyResults = [];

            recentDeliveries.forEach(delivery => {
                const analysis = {
                    delivery_id: delivery.id,
                    route: `${delivery.fromCity} → ${delivery.toCity}`,
                    product: PRODUCTS[delivery.productType].name,
                    vehicle_type: VEHICLES[vehicles[delivery.vehicleId].type].name,
                    distance: delivery.distance,
                    efficiency_score: 0,
                    problems: [],
                    recommendations: [],
                    suggested_new_warehouse: null,
                    suggested_vehicle: null,
                    potential_savings: 0,
                    vehicle: vehicles[delivery.vehicleId],
                    delivery: delivery,
                    product_spoiled: delivery.productSpoiled,
                    days_in_transit: delivery.daysInTransit,
                    shelf_life: PRODUCTS[delivery.productType].shelfLife,
                };

                if (delivery.productSpoiled) {
                    analysis.efficiency_score = 0;
                    analysis.problems.push(`🗑️ Продукт ИСПОРТИЛСЯ!`);
                    analysis.verdict = "❌ КРИТИЧЕСКИ НЕЭФФЕКТИВЕН";
                    analysis.recommendations.push(`🏭 Разместить промежуточный склад`);
                    analysis.recommendations.push(`🚀 Использовать более быстрый транспорт`);
                    efficiencyResults.push(analysis);
                    return;
                }

                let score = 100;
                const weight = PRODUCTS[delivery.productType].weight * delivery.quantity;
                const loadPct = (weight / analysis.vehicle.capacity) * 100;
                
                if (loadPct < 40) {
                    score -= 25;
                    analysis.problems.push(`📉 Низкая загрузка (${loadPct.toFixed(0)}%)`);
                } else if (loadPct < 60) {
                    score -= 10;
                }

                if (delivery.distance > 1000) {
                    score -= 20;
                    analysis.problems.push(`📏 Очень длинный маршрут`);
                } else if (delivery.distance > 600) {
                    score -= 10;
                }

                analysis.efficiency_score = Math.max(0, score);

                if (score >= 80) analysis.verdict = "✅ Эффективен";
                else if (score >= 60) analysis.verdict = "⚠️ Требует оптимизации";
                else analysis.verdict = "❌ Неэффективен";

                efficiencyResults.push(analysis);
            });

            efficiencyResults.sort((a, b) => a.efficiency_score - b.efficiency_score);
            updateEfficiencyTable();
            log(`🎯 Анализ выполнен: ${efficiencyResults.length} маршрутов`, "success");
        }

        function updateEfficiencyTable() {
            const tbody = document.querySelector('#efficiency-table tbody');
            tbody.innerHTML = '';

            let totalSavings = 0;
            let criticalCount = 0;
            let spoiledCount = 0;

            efficiencyResults.forEach((r, idx) => {
                const score = r.efficiency_score;
                let scoreClass = 'score-high';
                if (r.product_spoiled) {
                    scoreClass = 'score-spoiled';
                    criticalCount++;
                    spoiledCount++;
                } else if (score < 60) {
                    scoreClass = 'score-low';
                    criticalCount++;
                } else if (score < 80) {
                    scoreClass = 'score-medium';
                }

                const problemsText = r.problems.length > 0 ? r.problems.slice(0, 2).join('<br>') : '—';
                const shelfInfo = `${r.shelf_life} дн. (в пути: ${r.days_in_transit} дн.)`;

                tbody.innerHTML += `
                    <tr onclick="showRecommendations(${idx})" style="cursor: pointer;">
                        <td>${r.delivery_id}</td>
                        <td>${r.route}</td>
                        <td>${r.product} / ${r.vehicle_type}</td>
                        <td>${r.distance.toFixed(0)} км</td>
                        <td><span class="score-badge ${scoreClass}">${score.toFixed(0)}/100</span></td>
                        <td style="font-size: 0.8rem;">${problemsText}</td>
                        <td style="color: ${r.product_spoiled ? 'var(--spoiled)' : 'inherit'};">${shelfInfo}${r.product_spoiled ? ' 🗑️' : ''}</td>
                        <td style="color: ${r.product_spoiled ? 'var(--spoiled)' : score >= 80 ? 'var(--success)' : score >= 60 ? 'var(--warning)' : 'var(--danger)'};">${r.verdict}</td>
                    </tr>
                `;

                totalSavings += r.potential_savings;
            });

            const avgScore = efficiencyResults.reduce((sum, r) => sum + r.efficiency_score, 0) / efficiencyResults.length;

            document.getElementById('summary-analyzed').textContent = efficiencyResults.length;
            document.getElementById('summary-avg').textContent = `${avgScore.toFixed(0)}/100`;
            document.getElementById('summary-critical').textContent = criticalCount;
            document.getElementById('summary-spoiled').textContent = spoiledCount;
            document.getElementById('summary-savings').textContent = `${totalSavings.toFixed(0)} ₽`;
            document.getElementById('eff-summary').style.display = 'flex';
        }

