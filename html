            }).join('');

            const utilization = (wh.currentLoad / wh.capacity) * 100;
            summary.textContent = `Всего: ${totalQty} ед. | ${totalWeight.toFixed(1)} кг | Загрузка: ${utilization.toFixed(1)}%`;
