        // Create delivery
        function createDelivery(e) {
            e.preventDefault();

            const fromWhId = document.getElementById('from-warehouse').value;
            const toWhId = document.getElementById('to-warehouse').value;
            const productType = document.getElementById('product-type').value;
            const vehicleType = document.getElementById('vehicle-type').value;
            const quantity = parseInt(document.getElementById('quantity').value);

            if (fromWhId === toWhId) {
                alert('Выберите разные склады!');
                return;
            }

            const fromWh = warehouses[fromWhId];
            const toWh = warehouses[toWhId];

            let product = null;
            let productId = null;
            for (const [pid, p] of Object.entries(fromWh.products)) {
                if (p.type === productType && p.quantity >= quantity) {
                    product = p;
                    productId = pid;
                    break;
                }
            }

            if (!product) {
                alert(`Товар не найден на складе`);
                return;
            }

            const age = currentDay - product.productionDay;
            const shelfLife = PRODUCTS[productType].shelfLife;
            const remaining = shelfLife - age;

            if (remaining <= 0) {
                alert(`⚠️ Товар уже испортился!`);
                return;
            }

            let vehicle = null;
            for (const v of Object.values(vehicles)) {
                if (v.type === vehicleType && v.isAvailable) {
                    const weight = PRODUCTS[productType].weight * quantity;
                    if (v.currentLoad + weight <= v.capacity) {
                        vehicle = v;
                        break;
                    }
                }
            }

            if (!vehicle) {
                alert(`Нет доступного транспорта`);
                return;
            }

            const fromCoords = CITIES[fromWh.city];
            const toCoords = CITIES[toWh.city];
            const distance = calculateDistance(fromCoords, toCoords);
            const estimatedTimeHours = distance / vehicle.speed;
            const estimatedDays = Math.ceil(estimatedTimeHours / 24);
            const fuel = (distance / 100) * vehicle.fuelConsumption;

            if (estimatedDays > remaining) {
                alert(`⚠️ Продукт испортится в пути!`);
                return;
            }

            fromWh.products[productId].quantity -= quantity;
            fromWh.currentLoad -= PRODUCTS[productType].weight * quantity;
            fromWh.totalShipped += quantity;

            vehicle.currentLoad += PRODUCTS[productType].weight * quantity;
            vehicle.isAvailable = false;
            vehicle.totalDistance += distance;
            vehicle.totalFuel += fuel;

            const delivery = {
                id: `DL-${String(++idCounter).padStart(4, '0')}`,
                fromCity: fromWh.city,
                toCity: toWh.city,
                fromWarehouse: fromWh.name,
                toWarehouse: toWh.name,
                productType,
                quantity,
                vehicleId: vehicle.id,
                distance,
                estimatedTimeHours,
                estimatedDays,
                fuelCost: fuel * 50,
                status: 'PLANNED',
                createdAt: new Date(),
                productionDay: product.productionDay,
                daysInTransit: 0,
                productSpoiled: false,
                departureDay: 0
            };

            deliveries.push(delivery);
            log(`✅ Доставка создана: ${fromWh.city} → ${toWh.city}`, "success");
            
            document.getElementById('delivery-form').reset();
            updateUI();
        }

        function calculateDistance(coord1, coord2) {
            const R = 6371;
            const dLat = (coord2[0] - coord1[0]) * Math.PI / 180;
            const dLon = (coord2[1] - coord1[1]) * Math.PI / 180;
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                      Math.cos(coord1[0] * Math.PI / 180) * Math.cos(coord2[0] * Math.PI / 180) *
                      Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            return R * c;
        }

        function simulateAll() {
            let totalDaysPassed = 0;
            while (deliveries.length > 0 && totalDaysPassed < 100) {
                currentDay++;
                document.getElementById('current-day').textContent = currentDay;
                
                Object.values(warehouses).forEach(wh => {
                    let spoiledQty = 0;
                    let spoiledWeight = 0;
                    const toRemove = [];

                    Object.entries(wh.products).forEach(([pid, product]) => {
                        const age = currentDay - product.productionDay;
                        if (age >= PRODUCTS[product.type].shelfLife) {
                            spoiledQty += product.quantity;
                            spoiledWeight += product.weight;
                            toRemove.push(pid);
                        }
                    });

                    toRemove.forEach(pid => delete wh.products[pid]);
                    wh.currentLoad -= spoiledWeight;
                    wh.totalSpoiled += spoiledQty;
                });

                const toRemoveDel = [];
                deliveries.forEach(d => {
                    if (d.status === 'PLANNED') {
                        d.status = 'IN_TRANSIT';
                        d.departureDay = currentDay;
                        d.daysInTransit = 0;
                    } else if (d.status === 'IN_TRANSIT') {
                        d.daysInTransit++;
                        const arrivalDay = d.departureDay + d.estimatedDays;
                        const productAgeAtArrival = arrivalDay - d.productionDay;
                        const shelfLife = PRODUCTS[d.productType].shelfLife;

                        if (productAgeAtArrival >= shelfLife) {
                            d.productSpoiled = true;
                            d.status = 'SPOILED';
                            d.completedAt = new Date();
                            const vehicle = vehicles[d.vehicleId];
                            vehicle.currentLoad -= PRODUCTS[d.productType].weight * d.quantity;
                            vehicle.isAvailable = true;
                            vehicle.deliveriesCompleted++;
                            deliveryHistory.push(d);
                            toRemoveDel.push(d);
                            return;
                        }

                        if (d.daysInTransit >= d.estimatedDays) {
                            d.status = 'DELIVERED';
                            d.completedAt = new Date();
                            const vehicle = vehicles[d.vehicleId];
                            vehicle.currentLoad -= PRODUCTS[d.productType].weight * d.quantity;
                            vehicle.isAvailable = true;
                            vehicle.deliveriesCompleted++;

                            const toWh = Object.values(warehouses).find(w => w.name === d.toWarehouse);
                            if (toWh) {
                                const productId = `PR-${d.productType}-${Date.now()}-${Math.random()}`;
                                toWh.products[productId] = {
                                    type: d.productType,
                                    quantity: d.quantity,
                                    weight: PRODUCTS[d.productType].weight * d.quantity,
                                    volume: PRODUCTS[d.productType].volume * d.quantity,
                                    productionDay: d.productionDay
                                };
                                toWh.currentLoad += PRODUCTS[d.productType].weight * d.quantity;
                                toWh.totalReceived += d.quantity;
                            }
                            deliveryHistory.push(d);
                            toRemoveDel.push(d);
                        }
                    }
                });

                deliveries = deliveries.filter(d => !toRemoveDel.includes(d));
                totalDaysPassed++;
            }

            nextDayCountdown = DAY_INTERVAL_MS / 1000;
            log(`⏩ Прокручено дней: ${totalDaysPassed}`, "success");
            updateUI();
        }

