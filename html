                ["WH-0006", "Сибирский", "Новосибирск", 30000, -5, 20],
            ];

            defaultWarehouses.forEach(([id, name, city, capacity, tempMin, tempMax]) => {
                warehouses[id] = {
                    id, name, city, capacity, tempMin, tempMax,
                    currentLoad: 0, products: {}, totalReceived: 0, totalShipped: 0, totalSpoiled: 0
                };
                Object.keys(PRODUCTS).forEach((type, idx) => {
                    const qty = [500, 1000, 300, 200, 400, 600][idx];
                    const productId = `PR-${type}-${id.slice(-3)}`;
                    warehouses[id].products[productId] = {
                        type, quantity: qty,
                        weight: PRODUCTS[type].weight * qty,
                        volume: PRODUCTS[type].volume * qty,
                        productionDay: 0
                    };
                    warehouses[id].currentLoad += PRODUCTS[type].weight * qty;
                });
            });

            const defaultVehicles = [
                ["TR-0001", "TRUCK"], ["TR-0002", "TRUCK"], ["TR-0003", "TRUCK"],
                ["GZ-0001", "GAZELLE"], ["GZ-0002", "GAZELLE"], ["GZ-0003", "GAZELLE"],
                ["CR-0001", "CAR"], ["CR-0002", "CAR"],
            ];

            defaultVehicles.forEach(([id, type]) => {
                vehicles[id] = {
                    id, type, ...VEHICLES[type],
                    currentLoad: 0, isAvailable: true,
                    totalDistance: 0, totalFuel: 0, deliveriesCompleted: 0
                };
            });

            populateSelects();
        }

        // Map
        function initMap() {
            mapCanvas = document.getElementById('custom-map');
            mapCtx = mapCanvas.getContext('2d');
            resizeCanvas();
            window.addEventListener('resize', () => {
                resizeCanvas();
                drawMap();
            });
            drawMap();
        }

        function resizeCanvas() {
            const container = mapCanvas.parentElement;
            mapCanvas.width = container.clientWidth;
            mapCanvas.height = window.innerWidth <= 480 ? 350 : window.innerWidth <= 768 ? 400 : 500;
        }

        function toScreen(lat, lon) {
            const w = mapCanvas.width;
            const h = mapCanvas.height;
            const margin = window.innerWidth <= 768 ? 30 : 60;
            const xNorm = (lon - RUSSIA_BOUNDS.minLon) / (RUSSIA_BOUNDS.maxLon - RUSSIA_BOUNDS.minLon);
            const yNorm = 1.0 - (lat - RUSSIA_BOUNDS.minLat) / (RUSSIA_BOUNDS.maxLat - RUSSIA_BOUNDS.minLat);
            return {
                x: margin + xNorm * (w - 2 * margin),
                y: margin + yNorm * (h - 2 * margin)
            };
        }

        function drawMap() {
            const w = mapCanvas.width;
            const h = mapCanvas.height;

            const gradient = mapCtx.createLinearGradient(0, 0, 0, h);
            gradient.addColorStop(0, '#0a0f1e');
            gradient.addColorStop(0.5, '#141e37');
            gradient.addColorStop(1, '#1e2d4b');
            mapCtx.fillStyle = gradient;
            mapCtx.fillRect(0, 0, w, h);

            // Grid
            mapCtx.strokeStyle = 'rgba(50, 70, 100, 0.3)';
            mapCtx.lineWidth = 0.5;
            mapCtx.setLineDash([3, 5]);
            mapCtx.fillStyle = 'rgba(100, 120, 150, 0.7)';
            mapCtx.font = window.innerWidth <= 768 ? '8px Arial' : '10px Arial';

            for (let lat = 45; lat <= 70; lat += 5) {
                const p = toScreen(lat, RUSSIA_BOUNDS.minLon);
                mapCtx.beginPath();
                mapCtx.moveTo(0, p.y);
                mapCtx.lineTo(w, p.y);
                mapCtx.stroke();
                if (window.innerWidth > 768) {
                    mapCtx.fillText(`${lat}°N`, 5, p.y - 3);
                }
            }
            for (let lon = 30; lon <= 180; lon += 15) {
                const p = toScreen(RUSSIA_BOUNDS.minLat, lon);
                mapCtx.beginPath();
                mapCtx.moveTo(p.x, 0);
                mapCtx.lineTo(p.x, h);
                mapCtx.stroke();
                if (window.innerWidth > 768) {
                    mapCtx.fillText(`${lon}°E`, p.x + 2, h - 5);
                }
            }
            mapCtx.setLineDash([]);

            // Russia outline
            mapCtx.beginPath();
            RUSSIA_OUTLINE.forEach(([lat, lon], i) => {
                const p = toScreen(lat, lon);
                if (i === 0) mapCtx.moveTo(p.x, p.y);
                else mapCtx.lineTo(p.x, p.y);
            });
            mapCtx.closePath();
            mapCtx.fillStyle = 'rgba(40, 70, 110, 0.25)';
            mapCtx.fill();
            mapCtx.strokeStyle = 'rgba(80, 130, 180, 0.7)';
            mapCtx.lineWidth = 1.5;
            mapCtx.stroke();

            // Roads
            const drawnRoads = new Set();
            ROADS.forEach(([c1, c2, dist, quality]) => {
                if (!CITIES[c1] || !CITIES[c2]) return;
                const key = [c1, c2].sort().join('|');
                if (drawnRoads.has(key)) return;
                drawnRoads.add(key);

                const p1 = toScreen(...CITIES[c1]);
                const p2 = toScreen(...CITIES[c2]);

                let color;
                if (quality >= 0.85) color = 'rgba(100, 150, 200, 0.6)';
                else if (quality >= 0.75) color = 'rgba(150, 130, 100, 0.6)';
                else color = 'rgba(180, 100, 100, 0.6)';

                mapCtx.strokeStyle = color;
                mapCtx.lineWidth = 1.5;
                mapCtx.setLineDash([6, 4]);
                mapCtx.beginPath();
                mapCtx.moveTo(p1.x, p1.y);
                mapCtx.lineTo(p2.x, p2.y);
                mapCtx.stroke();
                mapCtx.setLineDash([]);
            });

            // Delivery routes
            const allDeliveries = [...deliveries, ...deliveryHistory.slice(-10)];
            allDeliveries.forEach(d => {
                const from = CITIES[d.fromCity];
                const to = CITIES[d.toCity];
                if (!from || !to) return;
                const p1 = toScreen(...from);
                const p2 = toScreen(...to);

                let color, lineWidth = 3;
                if (d.status === 'IN_TRANSIT') color = '#00ff96';
                else if (d.status === 'SPOILED') color = '#FF5722';
                else if (d.status === 'DELIVERED') { color = 'rgba(100, 200, 100, 0.6)'; lineWidth = 2; }
                else { color = '#ffd93d'; lineWidth = 2; mapCtx.setLineDash([8, 6]); }

                mapCtx.strokeStyle = color;
                mapCtx.lineWidth = lineWidth;
                mapCtx.beginPath();
                mapCtx.moveTo(p1.x, p1.y);
                mapCtx.lineTo(p2.x, p2.y);
                mapCtx.stroke();
                mapCtx.setLineDash([]);

                // Arrow
                const dx = p2.x - p1.x;
                const dy = p2.y - p1.y;
                const length = Math.sqrt(dx*dx + dy*dy);
                if (length > 0) {
                    const ndx = dx / length;
                    const ndy = dy / length;
                    const midX = (p1.x + p2.x) / 2;
                    const midY = (p1.y + p2.y) / 2;
                    const arrowSize = 8;

                    mapCtx.fillStyle = color;
                    mapCtx.beginPath();
                    mapCtx.moveTo(midX, midY);
                    mapCtx.lineTo(midX - ndx*arrowSize - ndy*arrowSize*0.5, midY - ndy*arrowSize + ndx*arrowSize*0.5);
                    mapCtx.lineTo(midX - ndx*arrowSize + ndy*arrowSize*0.5, midY - ndy*arrowSize - ndx*arrowSize*0.5);
                    mapCtx.closePath();
                    mapCtx.fill();
                }
            });

            // Cities
            Object.entries(CITIES).forEach(([city, coords]) => {
                const p = toScreen(...coords);
                const wh = Object.values(warehouses).find(w => w.city === city);

                if (wh) {
                    const utilization = (wh.currentLoad / wh.capacity) * 100;
                    let color;
                    if (utilization > 80) color = '#ff6464';
                    else if (utilization > 50) color = '#ffc832';
                    else color = '#32c878';

                    const glow = mapCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, 25);
                    glow.addColorStop(0, color + 'aa');
                    glow.addColorStop(1, color + '00');
                    mapCtx.fillStyle = glow;
                    mapCtx.beginPath();
                    mapCtx.arc(p.x, p.y, 25, 0, Math.PI * 2);
                    mapCtx.fill();

                    const size = 10 + utilization / 20;
                    mapCtx.fillStyle = color;
                    mapCtx.strokeStyle = 'rgba(255, 255, 255, 0.7)';
                    mapCtx.lineWidth = 2;
                    mapCtx.beginPath();
                    mapCtx.arc(p.x, p.y, size, 0, Math.PI * 2);
                    mapCtx.fill();
                    mapCtx.stroke();

                    if (window.innerWidth > 768) {
                        mapCtx.fillStyle = 'white';
                        mapCtx.font = 'bold 11px Arial';
                        mapCtx.textAlign = 'center';
                        mapCtx.fillText('🏭', p.x, p.y + 4);
                        mapCtx.textAlign = 'left';
                    }
                } else {
                    mapCtx.fillStyle = '#b4c8dc';
                    mapCtx.strokeStyle = '#dce6f5';
                    mapCtx.lineWidth = 1;
                    mapCtx.beginPath();
                    mapCtx.arc(p.x, p.y, 4, 4, 0, Math.PI * 2);
                    mapCtx.fill();
                    mapCtx.stroke();
                }

                mapCtx.fillStyle = '#e6f0ff';
                mapCtx.font = wh ? 'bold 11px Arial' : '10px Arial';
                mapCtx.fillText(city, p.x + 14, p.y + 4);
            });

            // Day indicator
            const dayBoxX = w - 180;
            const dayBoxY = 15;
            mapCtx.fillStyle = 'rgba(20, 40, 70, 0.9)';
            mapCtx.strokeStyle = '#00d4ff';
            mapCtx.lineWidth = 2;
            roundRect(mapCtx, dayBoxX, dayBoxY, 165, 50, 8);
            mapCtx.fill();
            mapCtx.stroke();

            mapCtx.fillStyle = '#c8dcf0';
            mapCtx.font = '11px Arial';
            mapCtx.fillText('📅 Текущий день:', dayBoxX + 10, dayBoxY + 20);

            mapCtx.fillStyle = '#00d4ff';
            mapCtx.font = 'bold 20px Arial';
            mapCtx.fillText(String(currentDay), dayBoxX + 10, dayBoxY + 43);
        }

        function roundRect(ctx, x, y, width, height, radius) {
            ctx.beginPath();
            ctx.moveTo(x + radius, y);
            ctx.lineTo(x + width - radius, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
            ctx.lineTo(x + width, y + height - radius);
            ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
            ctx.lineTo(x + radius, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
            ctx.lineTo(x, y + radius);
            ctx.quadraticCurveTo(x, y, x + radius, y);
            ctx.closePath();
        }

        // Timers
        function startTimers() {
            setInterval(() => {
                nextDayCountdown--;
                if (nextDayCountdown <= 0) {
                    nextDayCountdown = DAY_INTERVAL_MS / 1000;
                    advanceDay();
                }
                document.getElementById('next-day-timer').textContent = nextDayCountdown;
            }, 1000);

            setInterval(() => {
                updateMetrics();
                drawMap();
            }, 2000);
        }

        function advanceDay() {
            currentDay++;
            document.getElementById('current-day').textContent = currentDay;
            log(`📅 Наступил день ${currentDay}`, "day");

            let totalSpoiled = 0;
            Object.values(warehouses).forEach(wh => {
                let spoiledQty = 0;
                let spoiledWeight = 0;
                const toRemove = [];

                Object.entries(wh.products).forEach(([pid, product]) => {
                    const age = currentDay - product.productionDay;
                    if (age >= PRODUCTS[product.type].shelfLife) {
                        spoiledQty += product.quantity;
                        spoiledWeight += product.weight;
                        toRemove.push(pid);
                    }
                });

                toRemove.forEach(pid => delete wh.products[pid]);
                wh.currentLoad -= spoiledWeight;
                wh.totalSpoiled += spoiledQty;
                totalSpoiled += spoiledQty;

                if (spoiledQty > 0) {
                    log(`🗑️ На складе '${wh.name}' испортилось ${spoiledQty} ед.`, "spoiled");
                }
            });

            if (totalSpoiled === 0) {
                log(`✅ Все продукты свежие`, "success");
            }

            const toRemove = [];
            deliveries.forEach(d => {
                if (d.status === 'PLANNED') {
                    d.status = 'IN_TRANSIT';
                    d.startedAt = new Date();
                    d.departureDay = currentDay;
                    d.daysInTransit = 0;
                    log(`🚚 Доставка ${d.id}: отправлена`, "info");
                } else if (d.status === 'IN_TRANSIT') {
                    d.daysInTransit++;

                    const arrivalDay = d.departureDay + d.estimatedDays;
                    const productAgeAtArrival = arrivalDay - d.productionDay;
                    const shelfLife = PRODUCTS[d.productType].shelfLife;

                    if (productAgeAtArrival >= shelfLife) {
                        d.productSpoiled = true;
                        d.status = 'SPOILED';
                        d.completedAt = new Date();

                        const vehicle = vehicles[d.vehicleId];
                        vehicle.currentLoad -= PRODUCTS[d.productType].weight * d.quantity;
                        vehicle.isAvailable = true;
                        vehicle.deliveriesCompleted++;

                        deliveryHistory.push(d);
                        toRemove.push(d);
                        log(`🗑️ Доставка ${d.id}: ПРОДУКТ ИСПОРТИЛСЯ!`, "spoiled");
                        return;
                    }

                    if (d.daysInTransit >= d.estimatedDays) {
                        d.status = 'DELIVERED';
                        d.completedAt = new Date();

                        const vehicle = vehicles[d.vehicleId];
                        vehicle.currentLoad -= PRODUCTS[d.productType].weight * d.quantity;
                        vehicle.isAvailable = true;
                        vehicle.deliveriesCompleted++;

                        const toWh = Object.values(warehouses).find(w => w.name === d.toWarehouse);
                        if (toWh) {
                            const productId = `PR-${d.productType}-${Date.now()}-${Math.random()}`;
                            toWh.products[productId] = {
                                type: d.productType,
                                quantity: d.quantity,
                                weight: PRODUCTS[d.productType].weight * d.quantity,
                                volume: PRODUCTS[d.productType].volume * d.quantity,
                                productionDay: d.productionDay
                            };
                            toWh.currentLoad += PRODUCTS[d.productType].weight * d.quantity;
                            toWh.totalReceived += d.quantity;
                        }

                        deliveryHistory.push(d);
                        toRemove.push(d);
                        log(`✅ Доставка ${d.id}: доставлена`, "success");
                    }
                }
            });

            deliveries = deliveries.filter(d => !toRemove.includes(d));
            updateUI();
        }

