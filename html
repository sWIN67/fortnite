                    <strong>Эффективность:</strong> <span class="score-badge ${r.product_spoiled ? 'score-spoiled' : r.efficiency_score >= 80 ? 'score-high' : r.efficiency_score >= 60 ? 'score-medium' : 'score-low'}">
                        ${r.efficiency_score.toFixed(0)}/100
                    </span>
                </div>
            `;

            if (r.product_spoiled) {
