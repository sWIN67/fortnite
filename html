        // Update UI
        function updateMetrics() {
            const totalDeliveries = deliveryHistory.length;
            const activeDeliveries = deliveries.length;
            const totalFuelCost = deliveryHistory.reduce((sum, d) => sum + d.fuelCost, 0);
            const totalDistance = deliveryHistory.reduce((sum, d) => sum + d.distance, 0);
            
            const availableVehicles = Object.values(vehicles).filter(v => v.isAvailable).length;
            const totalCargo = Object.values(warehouses).reduce((sum, w) => sum + w.currentLoad, 0);
            
            const onTime = deliveryHistory.filter(d => d.status === 'DELIVERED').length;
            const onTimeRate = totalDeliveries > 0 ? (onTime / totalDeliveries * 100) : 0;
            
            const spoiled = deliveryHistory.filter(d => d.status === 'SPOILED').length;
            
            const metrics = [
                { icon: '📅', value: currentDay, label: 'День', color: '#00BCD4' },
                { icon: '📦', value: totalDeliveries, label: 'Доставок', color: '#4CAF50' },
                { icon: '🚚', value: activeDeliveries, label: 'Активных', color: '#2196F3' },
                { icon: '⛽', value: `${totalFuelCost.toFixed(0)} ₽`, label: 'Топливо', color: '#FF9800' },
                { icon: '🛣️', value: `${totalDistance.toFixed(0)} км`, label: 'Пробег', color: '#9C27B0' },
                { icon: '🚛', value: availableVehicles, label: 'Транспорт', color: '#607D8B' },
                { icon: '⏰', value: `${onTimeRate.toFixed(1)}%`, label: 'Сроки', color: '#E91E63' },
                { icon: '🗑️', value: spoiled, label: 'Испорчено', color: '#FF5722' },
                { icon: '🏭', value: `${totalCargo.toFixed(0)} кг`, label: 'Груз', color: '#795548' },
            ];
            
            const grid = document.getElementById('metrics-grid');
            grid.innerHTML = metrics.map(m => `
                <div class="metric-card">
                    <div class="metric-icon">${m.icon}</div>
                    <div class="metric-value" style="color: ${m.color}">${m.value}</div>
                    <div class="metric-label">${m.label}</div>
                </div>
            `).join('');
        }

        function updateTables() {
            const whTbody = document.querySelector('#warehouses-table tbody');
            whTbody.innerHTML = Object.values(warehouses).map(wh => {
                const utilization = (wh.currentLoad / wh.capacity) * 100;
                const productCount = Object.values(wh.products).reduce((sum, p) => sum + p.quantity, 0);
                let loadColor = '#6bff6b';
                if (utilization > 80) loadColor = '#ff6b6b';
                else if (utilization > 50) loadColor = '#ffd93d';
                
                return `
                    <tr>
                        <td>${wh.id}</td>
                        <td>${wh.name}</td>
                        <td>${wh.city}</td>
                        <td style="color: ${loadColor}">${utilization.toFixed(1)}%</td>
                        <td>${productCount}</td>
                        <td style="color: ${wh.totalSpoiled > 0 ? 'var(--spoiled)' : 'inherit'}; font-weight: ${wh.totalSpoiled > 0 ? 'bold' : 'normal'};">${wh.totalSpoiled}</td>
                    </tr>
                `;
            }).join('');
            
            const vehTbody = document.querySelector('#vehicles-table tbody');
            vehTbody.innerHTML = Object.values(vehicles).map(v => {
                const loadPercent = (v.currentLoad / v.capacity) * 100;
                const status = v.isAvailable ? 
                    '<span class="badge badge-success">✅ Доступен</span>' : 
                    '<span class="badge badge-danger">🚫 Занят</span>';
                
                return `
                    <tr>
                        <td>${v.id}</td>
                        <td>${VEHICLES[v.type].name}</td>
                        <td>${v.capacity} кг</td>
                        <td>${loadPercent.toFixed(1)}%</td>
                        <td>${status}</td>
                    </tr>
                `;
            }).join('');
            
            const activeTbody = document.querySelector('#active-deliveries-table tbody');
            activeTbody.innerHTML = deliveries.map(d => {
                let statusBadge;
                if (d.status === 'IN_TRANSIT') statusBadge = '<span class="badge badge-info">В пути</span>';
                else if (d.status === 'PLANNED') statusBadge = '<span class="badge badge-warning">Запланирована</span>';
                else if (d.status === 'SPOILED') statusBadge = '<span class="badge badge-spoiled">🗑️ Испорчено</span>';
                else statusBadge = '<span class="badge badge-success">Доставлена</span>';
                
                const age = currentDay - d.productionDay;
                const shelfLife = PRODUCTS[d.productType].shelfLife;
                const remaining = shelfLife - age;
                const arrivalAge = age + d.estimatedDays;
                const remainingAtArrival = shelfLife - arrivalAge;
                
                let shelfColor = remainingAtArrival > 3 ? 'var(--success)' : remainingAtArrival > 0 ? 'var(--warning)' : 'var(--spoiled)';
                
                return `
                    <tr>
                        <td>${d.id}</td>
                        <td>${d.fromCity} → ${d.toCity}</td>
                        <td>${PRODUCTS[d.productType].name}</td>
                        <td>${d.quantity}</td>
                        <td>${VEHICLES[vehicles[d.vehicleId].type].name}</td>
                        <td>${d.distance.toFixed(0)} км</td>
                        <td>${d.daysInTransit} / ~${d.estimatedDays} дн.</td>
                        <td style="color: ${shelfColor}; font-weight: bold;">${shelfLife} дн. (ост: ${remainingAtArrival})</td>
                        <td>День ${d.departureDay}</td>
                        <td>${statusBadge}</td>
                    </tr>
                `;
            }).join('');
            
            const historyTbody = document.querySelector('#history-deliveries-table tbody');
            historyTbody.innerHTML = deliveryHistory.slice(-50).map(d => {
                let statusBadge;
                if (d.status === 'DELIVERED') statusBadge = '<span class="badge badge-success">✅ Доставлена</span>';
                else if (d.status === 'SPOILED') statusBadge = '<span class="badge badge-spoiled">🗑️ Испорчено</span>';
                else statusBadge = `<span class="badge badge-warning">${d.status}</span>`;
                
                return `
                    <tr>
                        <td>${d.id}</td>
                        <td>${d.fromCity} → ${d.toCity}</td>
                        <td>${PRODUCTS[d.productType].name}</td>
                        <td>${d.quantity}</td>
                        <td>${d.distance.toFixed(0)} км</td>
                        <td>${d.fuelCost.toFixed(0)} ₽</td>
                        <td>${d.daysInTransit} дн.</td>
                        <td>День ${d.departureDay}</td>
                        <td>${PRODUCTS[d.productType].shelfLife} дн.</td>
                        <td>${statusBadge}</td>
                    </tr>
                `;
            }).join('');
        }

        function updateUI() {
            document.getElementById('current-day').textContent = currentDay;
            updateMetrics();
            updateTables();
            updateProductsTable();
            drawMap();
        }

        function log(message, type = 'info') {
            const console = document.getElementById('log-console');
            const time = new Date().toLocaleTimeString('ru-RU');
            const className = `log-${type}`;
            console.innerHTML += `<div class="log-entry"><span class="log-time">[День ${currentDay} | ${time}]</span> <span class="${className}">${message}</span></div>`;
            console.scrollTop = console.scrollHeight;
        }

        function switchTab(tabName) {
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(`${tabName}-tab`).classList.add('active');
            
            if (tabName === 'map') {
                setTimeout(() => {
                    resizeCanvas();
                    drawMap();
                }, 100);
            }
        }

        function refreshAll() {
            updateUI();
            log('🔄 Обновлено', "success");
        }
    </script>
</body>
</html>
